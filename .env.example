# Copy to .env (gitignored). Every value has a default — with none of these set,
# the service runs on SQLite with no external dependencies.

# Storage. SQLite by default; point at Postgres to use Postgres:
CV_DATABASE_URL=sqlite:///./contact_verifier.db
# CV_DATABASE_URL=postgresql+psycopg://cv:cv@localhost:5432/contact_verifier

# Where the warehouse delivery export is written.
CV_WAREHOUSE_DIR=./warehouse

# Logging.
CV_LOG_JSON=true
CV_LOG_LEVEL=INFO

# External verification (DNS/MX).
CV_DNS_TIMEOUT_S=3.0
CV_DNS_MAX_RETRIES=3
CV_DNS_RATE_LIMIT_PER_S=20

# Optional error tracing. Off unless a DSN is set (this service holds contact data).
# CV_SENTRY_DSN=
